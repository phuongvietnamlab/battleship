# === BẮT BUỘC ===
DB_PASSWORD=CHANGE_ME_strong_random_password_32chars
REDIS_PASSWORD=CHANGE_ME_another_random_password
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# === TÙY CHỌN — WebAuthn (Passkey) ===
# RP_ID = domain name (e.g. battleshiponline.xyz in prod, localhost in dev)
# RP_ORIGIN = full origin (e.g. https://battleshiponline.xyz in prod, http://localhost:4000 in dev)
# If not set, falls back to SITE_ORIGIN or localhost defaults.
RP_ID=battleshiponline.xyz
RP_ORIGIN=https://battleshiponline.xyz

# === HOSTING ===
APP_BASE_URL=https://battleshiponline.xyz
CANONICAL_HOST=battleshiponline.xyz
